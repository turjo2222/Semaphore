 1005  cat > /ansible/playbooks/win_create_test.yml <<'EOF'
---
- name: Windows SSH Test Configuration
  hosts: windows
  gather_facts: false

  tasks:
    - name: Create C:\temp directory
      raw: mkdir C:\temp

    - name: Create MyFolder directory
      raw: mkdir C:\temp\MyFolder

    - name: Create test text file
      raw: echo Hello from Ansible > C:\temp\MyFolder\test.txt

    - name: Verify file content
      raw: type C:\temp\MyFolder\test.txt
      register: result

    - name: Show file content
      debug:
        var: result.stdout
EOF

 1006  ansible-playbook --syntax-check -i /ansible/inventory/hosts /ansible/playbooks/win_create_test.yml
