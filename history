 1008  cat > /ansible/playbooks/win_create_test.yml <<'EOF'
---
- name: Windows SSH Test Configuration
  hosts: windows
  gather_facts: false

  tasks:
    - name: Create C:\temp directory
      raw: powershell -Command "New-Item -ItemType Directory -Path 'C:\temp' -Force"

    - name: Create MyFolder directory
      raw: powershell -Command "New-Item -ItemType Directory -Path 'C:\temp\MyFolder' -Force"

    - name: Create test text file
      raw: powershell -Command "Set-Content -Path 'C:\temp\MyFolder\test.txt' -Value 'Hello from Ansible'"

    - name: Verify file content
      raw: powershell -Command "Get-Content 'C:\temp\MyFolder\test.txt'"
      register: result

    - name: Show file content
      debug:
        var: result.stdout
EOF

 1009  ansible-playbook -i /ansible/inventory/hosts /ansible/playbooks/win_create_test.yml
