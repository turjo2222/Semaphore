---
- name: Copy and Install Avro Keyboard
  hosts: windows
  gather_facts: false

  tasks:

    - name: Create installer folder
      ansible.windows.win_file:
        path: C:\temp\installer
        state: directory

    - name: Copy Avro installer from network share
      ansible.windows.win_shell: |
        Copy-Item "\\10.64.105.105\mostafa\Bangla\setup_avrokeyboard_5.6.0.exe" `
        -Destination "C:\temp\installer\setup_avrokeyboard_5.6.0.exe" `
        -Force

    - name: Run Avro installer silently
      ansible.windows.win_command: >
        C:\temp\installer\setup_avrokeyboard_5.6.0.exe /VERYSILENT /SUPPRESSMSGBOXES /NORESTART

    - name: Verify installer exists
      ansible.windows.win_stat:
        path: C:\temp\installer\setup_avrokeyboard_5.6.0.exe
      register: avro_file

    - name: Show result
      debug:
        var: avro_file.stat.exists
